<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_background"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diagnostics_panel_title"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/current_pid_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/currentPidText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/selected_interface_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/selectedInterfaceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/selected_ip_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/selectedIpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/port_bind_result_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/portBindResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/last_probe_result_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/lastProbeResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/probe_target_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/probeTargetText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/probe_detail_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/probeDetailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/hotspot_active_label"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_muted" />

        <TextView
            android:id="@+id/hotspotActiveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/proxy_ink" />
    </LinearLayout>
</LinearLayout>
